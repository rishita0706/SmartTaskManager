@model SmartTaskManager.Models.TaskMaster

<h2>Update Status: @Model.Title</h2>

<form asp-action="UpdateStatus" asp-route-id="@Model.TaskId" method="post">
    <div class="mb-3">
        <label>Status</label>
        <select name="statusId" class="form-control">
            <option value="1" selected="@(Model.StatusId == 1)">Pending</option>
            <option value="2" selected="@(Model.StatusId == 2)">In Progress</option>
            <option value="3" selected="@(Model.StatusId == 3)">Completed</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Update</button>
</form>