@{
    ViewData["Title"] = "AdminDashboard";
}

<h1>Admin Dashboard</h1>

<div class="row">

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Total Users</h5>
                <h2>@ViewBag.TotalUsers</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Total Tasks</h5>
                <h2>@ViewBag.TotalTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Total Departments</h5>
                <h2>@ViewBag.TotalDepartments</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Active Employees</h5>
                <h2>@ViewBag.ActiveEmployees</h2>
            </div>
        </div>
    </div>

</div>