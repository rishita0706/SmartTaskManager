@{
    ViewData["Title"] = "ManagerDashboard";
}

<h1>Manager Dashboard</h1>

<div class="mb-4">
    <a asp-controller="Task" asp-action="Create" class="btn btn-primary me-2">Create Task</a>
    <a asp-controller="Task" asp-action="Index" class="btn btn-secondary">View Team Tasks</a>
</div>

<div class="row">

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Tasks Assigned By Me</h5>
                <h2>@ViewBag.TasksAssignedByMe</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Pending Tasks</h5>
                <h2>@ViewBag.PendingTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Completed Tasks</h5>
                <h2>@ViewBag.CompletedTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>My Team Members</h5>
                <h2>@ViewBag.MyTeamMembers</h2>
            </div>
        </div>
    </div>

</div>