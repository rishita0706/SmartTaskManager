@{
    ViewData["Title"] = "EmployeeDashboard";
}

<h1>Employee Dashboard</h1>

<div class="mb-4">
    <a asp-controller="Task" asp-action="Index" class="btn btn-primary">My Tasks</a>
</div>

<div class="row">

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>My Tasks</h5>
                <h2>@ViewBag.MyTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Completed Tasks</h5>
                <h2>@ViewBag.CompletedTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Due Tasks</h5>
                <h2>@ViewBag.DueTasks</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h5>Recent Comments</h5>
                <h2>@ViewBag.RecentComments</h2>
            </div>
        </div>
    </div>

</div>