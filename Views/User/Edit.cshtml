@model SmartTaskManager.ViewModels.UserEditViewModel

<form asp-action="Edit">

    <input type="hidden" asp-for="UserId" />

    <div class="mb-3">
        <label>First Name</label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Last Name</label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Phone</label>
        <input asp-for="Phone" class="form-control" />
    </div>

    <div class="mb-3">
        <label>New Password (leave blank to keep current)</label>
        <input asp-for="NewPassword" type="password" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Role</label>
        <select asp-for="RoleId"
                asp-items="ViewBag.Roles"
                class="form-control">
        </select>
    </div>

    <div class="mb-3">
        <label>Department</label>
        <select asp-for="DepartmentId"
                asp-items="ViewBag.Departments"
                class="form-control">
        </select>
    </div>

    <div class="mb-3">
        <label>Manager</label>
        <select asp-for="ManagerId"
                asp-items="ViewBag.Managers"
                class="form-control">
            <option value="">-- None --</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Status</label>
        <input asp-for="IsActive" type="checkbox" />
    </div>

    <button class="btn btn-success">
        Update User
    </button>

</form>